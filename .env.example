EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=carona-app-4e8f6.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=carona-app-4e8f6
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=carona-app-4e8f6.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google Maps Platform
# Chave usada nas chamadas REST (Places API (New) + Routes API), embutida no app.
EXPO_PUBLIC_GOOGLE_MAPS_KEY=
# Chave do Maps SDK for Android (build-time, restrita por package + SHA-1).
# Só tem efeito em dev builds/produção; o Expo Go usa a chave da Expo.
GOOGLE_MAPS_ANDROID_API_KEY=

# DEV: "true" libera cadastro/uso de contas não-UFOP (para testar com 2 contas).
# Deve casar com devAllowAnyEmail() em firestore.rules. Deixe vazio em produção.
EXPO_PUBLIC_ALLOW_NON_UFOP=
